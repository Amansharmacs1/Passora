{
  "manifest_version": 3,
  "name": "Passora Extension",
  "version": "1.0",
  "description": "Secure password manager extension for Passora",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open Passora"
  },
  "background": {
    "service_worker": "background.js"
  }
}
